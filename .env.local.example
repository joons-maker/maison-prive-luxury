# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase 대시보드 > Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ⚠ NEXT_PUBLIC_ 접두사 절대 사용 금지 — 서버 API Route 전용
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── 관리자 인증 ──────────────────────────────────────────────────────────────
# 관리자 화면(/admin) 접근 비밀번호 — 배포 전 강력한 비밀번호로 변경 필수
LUXURY_ADMIN_PASSWORD=your_strong_password_here

# ─── 이메일 알림 (Resend) ─────────────────────────────────────────────────────
# https://resend.com 에서 API 키 발급
# 없으면 console.log로 fallback 처리됨 (알림 미발송, 문의 저장은 정상)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_NOTIFY_EMAIL=admin@yourdomain.com

# ─── 사이트 URL ───────────────────────────────────────────────────────────────
# 이메일 알림 내 관리자 링크 생성에 사용
# 로컬: http://localhost:3001 / 운영: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
